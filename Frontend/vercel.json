{
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://gymrats-api.onrender.com/api/:path*" },
    { "source": "/signup/:path*", "destination": "https://gymrats-api.onrender.com/signup/:path*" },
    { "source": "/trainer/:path*", "destination": "https://gymrats-api.onrender.com/trainer/:path*" },
    { "source": "/appointments/:path*", "destination": "https://gymrats-api.onrender.com/appointments/:path*" },
    { "source": "/appointments", "destination": "https://gymrats-api.onrender.com/appointments" },
    { "source": "/:path*", "destination": "/index.html" }
  ]
}
